# LeaderSmart environment variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git

# ==================== SUPABASE ====================
# Get these from https://supabase.com/dashboard/project/oisrzurefglwiaeqedyp/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://oisrzurefglwiaeqedyp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ==================== APP CONFIG ====================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=LeaderSmart

